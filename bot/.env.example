# ══════════════════════════════════════════════
# TradeGround Bot — приклад .env (скопіюй у .env)
# ══════════════════════════════════════════════

# ── Бот ───────────────────────────────────────
TOKEN=
BOT_USERNAME=
ADMINISTRATORS=[123456789]
WEBAPP_URL=https://example.com
BOT_API_KEY=
SUPPORT_MANAGER=https://t.me/support

# ── Канали / групи ────────────────────────────
MODERATION_GROUP_ID=
TRADE_CHANNEL_ID=
TRADE_GERMANY_CHANNEL_ID=

# ── Парсер: 3 групи модерації ─────────────────
# 1) Послуги → Hamburg-канал + маркетплейс
PARSER_MOD_SERVICES_HAMBURG_ID=-1003796207726
# 2) Послуги → Germany-канал + маркетплейс
PARSER_MOD_SERVICES_GERMANY_ID=-1003714727651
# 3) Товари → лише маркетплейс
PARSER_MOD_GOODS_ID=-1003901841142
# Канали публікації послуг (після ✅)
TRADE_SERVICES_CHANNEL_HAMBURG_ID=
TRADE_SERVICES_CHANNEL_GERMANY_ID=

# ── Платежі ───────────────────────────────────
MONOBANK_TOKEN=

# ── OpenAI (AI-фільтр / збагачення) ───────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PARSER_AI_ENABLED=1
PARSER_AI_SCREEN_ENABLED=1

# ── Парсер: загальні налаштування ─────────────
PARSER_INTERVAL_MIN=15
# Звіт адмінам після кожного планового циклу (0 — вимкнути)
PARSER_SCHEDULE_REPORT_ADMINS=1
PARSER_FETCH_LIMIT=100
PARSER_CURSOR_OVERLAP=25
PARSER_ROLLING_LOOKBACK=100
PARSER_DEDUP_ENABLED=0
PARSER_SERVICES_FETCH_LIMIT=100
PARSER_SERVICES_IGNORE_CURSOR=0
PARSER_DEDUP_ENABLED=1
PARSER_SERVICES_DEDUP_ENABLED=1
PARSER_TEXT_DEDUP_DAYS=2
PARSER_PENDING_DEDUP_HOURS=36
PARSER_FUZZY_DEDUP_THRESHOLD=0.94
PARSER_FUZZY_DEDUP_SAME_CHANNEL=1

# ══════════════════════════════════════════════
# Pyrogram-акаунти: керуються в боті
# Адмін-панель → «Парсер акаунти» (не через .env)
# Сесії: bot/parser/sessions/
# ══════════════════════════════════════════════
